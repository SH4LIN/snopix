{
	"name": "pixel-scout/pixel-scout",
	"description": "Image similarity search for WordPress media library",
	"version": "0.1.0",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"wp-phpunit/wp-phpunit": "^6.9.4",
		"phpunit/phpunit": "^13.1.8",
		"squizlabs/php_codesniffer": "^3.13.0",
		"wp-coding-standards/wpcs": "^3.3.0",
		"phpcompatibility/php-compatibility": "^9.3.5",
		"dealerdirect/phpcodesniffer-composer-installer": "^v1.2.1"
	},
	"scripts": {
		"test": "phpunit",
		"test-coverage": "phpunit --coverage-html=./coverage",
		"lint": "phpcs",
		"lint-fix": "phpcbf",
		"lint-strict": "phpcs -d error_reporting=-1"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}



