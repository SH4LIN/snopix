<?xml version="1.0"?>
<ruleset name="Pixel Scout">
	<description>WordPress Coding Standards for Pixel Scout Plugin</description>

	<file>includes/</file>
	<file>pixel-scout.php</file>
	<file>uninstall.php</file>
	<file>admin/views/</file>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/coverage/*</exclude-pattern>
	<exclude-pattern>*.js</exclude-pattern>
	<exclude-pattern>*.ts</exclude-pattern>
	<exclude-pattern>*.tsx</exclude-pattern>
	<exclude-pattern>*.css</exclude-pattern>

	<!-- WordPress meta-ruleset: includes Core + Docs + Extra -->
	<rule ref="WordPress">
		<exclude name="Generic.Files.LineLength" />
	</rule>

	<config name="testVersion" value="8.0-" />
	<rule ref="PHPCompatibility" />

	<rule ref="Generic.NamingConventions.UpperCaseConstantName" />

	<rule ref="Generic.Metrics.CyclomaticComplexity">
		<properties>
			<property name="complexity" value="15" />
			<property name="absoluteComplexity" value="20" />
		</properties>
	</rule>

	<rule ref="Generic.Metrics.NestingLevel">
		<properties>
			<property name="nestingLevel" value="5" />
			<property name="absoluteNestingLevel" value="8" />
		</properties>
	</rule>

	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="100" />
			<property name="absoluteLineLimit" value="120" />
			<property name="ignoreComments" value="true" />
		</properties>
		<severity>5</severity>
	</rule>

	<arg name="extensions" value="php" />
	<arg name="report" value="summary" />
	<arg name="colors" />
	<arg name="cache" value=".phpcs-cache" />
	<arg value="p" />
</ruleset>
