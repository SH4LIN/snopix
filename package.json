{
	"name": "snopix",
	"version": "0.1.2",
	"description": "Image similarity search for WordPress media library",
	"private": true,
	"scripts": {
		"dev": "npm run watch",
		"build": "run-p build:admin build:editor build:search",
		"build:admin": "npm run build --prefix admin/app",
		"build:editor": "wp-scripts build admin/editor/src/index.js --output-path=admin/editor/build",
		"build:search": "npm run build --prefix public/app",
		"watch": "run-p watch:admin watch:editor watch:search",
		"watch:admin": "npm run watch --prefix admin/app",
		"watch:editor": "wp-scripts start admin/editor/src/index.js --output-path=admin/editor/build",
		"watch:search": "npm run watch --prefix public/app",
		"build:editor:watch": "npm run watch:editor",
		"clean": "run-p clean:admin clean:editor clean:search",
		"clean:admin": "rm -rf admin/app/dist",
		"clean:editor": "rm -rf admin/editor/build",
		"clean:search": "rm -rf public/app/dist",
		"lint": "npm run lint:ts && npm run lint:styles",
		"lint:ts": "eslint admin/app/src --ext .ts,.tsx",
		"format": "prettier --write admin/app/src",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@types/node": "^22.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.23.0",
		"@typescript-eslint/parser": "^8.23.0",
		"@wordpress/env": "^11.5.0",
		"@wordpress/scripts": "^32.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.12"
	}
}
