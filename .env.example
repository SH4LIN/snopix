# Pixel Scout Test Environment

# WordPress URL (for Playwright E2E tests)
# Default: wp-env serves on http://localhost:8000
WORDPRESS_URL=http://localhost:8000

# WordPress Test Credentials
# These are the default credentials set by wp-env
WORDPRESS_USER=wordpress
WORDPRESS_PASSWORD=wordpress

# PHPUnit Database (local testing)
# Not needed if using wp-env, but required if running tests locally
DB_NAME=wordpress_test
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_CHARSET=utf8mb4

# CI/CD Mode
# Set to true when running in GitHub Actions or similar
CI=false





